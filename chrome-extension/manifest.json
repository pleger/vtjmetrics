{
  "manifest_version": 3,
  "name": "VTJMetrics for GitHub",
  "description": "Run JTMetrics on GitHub repositories, download JSON results, and visualize coupling metrics.",
  "version": "0.4.0",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://github.com/*",
    "https://api.github.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://github.com/*"
      ],
      "js": [
        "vendor/babel.min.js",
        "browser-engine.js",
        "vendor/d3.min.js",
        "content.js"
      ],
      "css": [
        "styles.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "icons/*",
        "metric-src/*"
      ],
      "matches": [
        "https://github.com/*"
      ]
    }
  ],
  "options_page": "options.html",
  "action": {
    "default_title": "VTJMetrics for GitHub",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png"
    }
  }
}
